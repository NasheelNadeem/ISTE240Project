<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Feedback Table</title>
    <style>
        table, th, td {
            border: 1px solid black;
        }
    </style>
</head>
<body>
    <h2>Feedback Table</h2>
    <table class="ui striped table">
        <thead>
            <tr>
                <th>Patient Name</th>
                <th>Doctor Name</th>
                <th>Rating</th>
                <th>Comment</th>
            </tr>
        </thead>
        <tbody>
        {{#feedbacks}}
            <tr>
                <td>{{patient.name}}</td>
                <td>{{doctor.name}}</td>
                <td>{{rating}}</td>
                <td>{{comment}}</td>
            </tr>
        {{/feedbacks}}
        </tbody>
    </table>

    <a href="/addFeedback">Add feedback</a>
</body>
</html>
