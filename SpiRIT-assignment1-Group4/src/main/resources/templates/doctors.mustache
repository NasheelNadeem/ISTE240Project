<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Appointment Table</title>
    <style>
        table, th, td {
            border: 1px solid black;
        }
    </style>
</head>
<body>
<h2>Doctor Directory</h2>
<table class="ui striped table">
    <thead>
    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Profession</th>
    </tr>
    </thead>
    <tbody>
    {{#doctors}}
        <tr>
            <td>{{doctorID}}</td>
            <td>{{name}}</td>
            <td>{{profession}}</td>
        </tr>
    {{/doctors}}
    </tbody>
</table>
<br>
<a href="/addDoctor">Add New Doctor</a>
<a href="/index.html">Back to Home Page</a>
</body>
</html>